#!/usr/bin/env bash
# claude-wt — Launch Claude Code in an isolated git worktree.
#
# Usage:
#   claude-wt                    # Interactive Claude in fresh worktree
#   claude-wt --resume           # Reuse existing worktree for this agent
#   claude-wt -- -p "fix bug"   # Pass args to claude
#
# This is Layer 1 of the worktree isolation system.
# Layer 2 (SessionStart hook) detects ARAGORA_WORKTREE_ACTIVE and skips.
# Layer 3 (CLAUDE.md) instructs Claude to call EnterWorktree if not isolated.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
AGENT="${CODEX_AGENT:-claude}"
BASE="${CODEX_BASE:-main}"
FORCE_NEW="--force-new"
CLAUDE_ARGS=()

# Parse our args vs claude args (separated by --)
while [[ $# -gt 0 ]]; do
  case "$1" in
    --resume)
      FORCE_NEW=""
      shift
      ;;
    --agent)
      AGENT="$2"
      shift 2
      ;;
    --base)
      BASE="$2"
      shift 2
      ;;
    --)
      shift
      CLAUDE_ARGS=("$@")
      break
      ;;
    *)
      CLAUDE_ARGS=("$@")
      break
      ;;
  esac
done

# Create or reuse an isolated worktree
WORKTREE_PATH=$(
  python3 "$REPO_ROOT/scripts/codex_worktree_autopilot.py" ensure \
    --agent "$AGENT" \
    --base "$BASE" \
    $FORCE_NEW \
    --reconcile \
    --print-path 2>/dev/null
)

if [[ -z "$WORKTREE_PATH" || ! -d "$WORKTREE_PATH" ]]; then
  echo "⚠ Worktree creation failed. Falling back to main repo." >&2
  WORKTREE_PATH="$REPO_ROOT"
fi

# Signal to Layer 2 (SessionStart hook) that we're already isolated
export ARAGORA_WORKTREE_ACTIVE=1
export ARAGORA_WORKTREE_PATH="$WORKTREE_PATH"

echo "▸ Worktree: $WORKTREE_PATH"
echo "▸ Agent: $AGENT | Base: $BASE"

cd "$WORKTREE_PATH"
exec claude "${CLAUDE_ARGS[@]}"

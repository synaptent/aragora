# Repos to watch (comma-separated)
ARAGORA_WATCH_REPOS=synaptent/aragora

# Poll interval in seconds
ARAGORA_WATCH_POLL_INTERVAL=120

# Review configuration
ARAGORA_WATCH_AGENTS=anthropic-api,openai-api
ARAGORA_WATCH_ROUNDS=2
ARAGORA_WATCH_DRY_RUN=false
ARAGORA_WATCH_GAUNTLET=false

# Filtering
ARAGORA_WATCH_SKIP_DRAFTS=true
ARAGORA_WATCH_SKIP_LABELS=wip,do-not-review

# Rate limiting
ARAGORA_WATCH_MAX_REVIEWS_PER_HOUR=10

# API Keys (required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
